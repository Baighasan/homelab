{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.2
    },
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "temperature": 0.1
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "ls*": "allow",
      "cat*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "wc*": "allow",
      "stat*": "allow",
      "file*": "allow",
      "pwd": "allow",
      "echo*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow"
    }
  },
}
